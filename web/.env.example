# Copie para .env.local. Estes valores são também o default do Docker build (web/Dockerfile) e do código (platform-admin.ts).

# --- API backend (deixe vazio ou remova para usar modo offline/localStorage) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Administrador da plataforma (painel /admin e admin.peladapro.cloud) ---
NEXT_PUBLIC_PLATFORM_ADMIN_EMAIL=admin@peladapro.cloud
# Local: podes usar uma senha de desenvolvimento. Produção: valor forte, só no servidor / --build-arg
NEXT_PUBLIC_PLATFORM_ADMIN_PASSWORD=PeladaPro!Admin2025
