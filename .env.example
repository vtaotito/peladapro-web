# ============================================
# PeladaPro — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# ---- PostgreSQL ----
POSTGRES_DB=boleiros
POSTGRES_USER=boleiros
POSTGRES_PASSWORD=TROQUE_AQUI_SENHA_SEGURA
POSTGRES_PORT=5433

# ---- Redis ----
REDIS_PORT=6380
REDIS_MAXMEMORY=256mb

# ---- API ----
JWT_SECRET=TROQUE_AQUI_CHAVE_JWT_SEGURA_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_URL=https://peladapro.cloud/api

# Painel admin (build-time; não committar valores reais)
NEXT_PUBLIC_PLATFORM_ADMIN_EMAIL=
NEXT_PUBLIC_PLATFORM_ADMIN_PASSWORD=

# ---- VPS / Deploy ----
# VPS_HOST=oliecare.cloud
# VPS_IP=72.62.11.30
# DOMAIN=peladapro.cloud

# ---- Portas em uso no VPS (referência) ----
# 80   - Nginx principal (SSL termination)
# 443  - Nginx principal (HTTPS)
# 3000 - Frontend Next.js
# 3001 - API NestJS
# 5433 - PostgreSQL (boleiros)
# 6380 - Redis (boleiros)
