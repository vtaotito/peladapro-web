# ============================================
# PeladaPro — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# ---- PostgreSQL ----
POSTGRES_DB=boleiros
POSTGRES_USER=boleiros
POSTGRES_PASSWORD=TROQUE_AQUI_SENHA_SEGURA
POSTGRES_PORT=5433

# ---- Redis ----
REDIS_PORT=6380
REDIS_MAXMEMORY=256mb

# ---- API ----
DATABASE_URL=postgresql://boleiros:TROQUE_AQUI_SENHA_SEGURA@boleiros-db:5432/boleiros
REDIS_URL=redis://boleiros-redis:6379
JWT_SECRET=TROQUE_AQUI_CHAVE_JWT_SEGURA_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=3001
NODE_ENV=production

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_URL=http://boleiros-api:3001
WEB_PORT=3000

# ---- VPS / Deploy ----
VPS_HOST=oliecare.cloud
VPS_IP=72.62.11.30
DOMAIN=peladapro.cloud

# ---- Portas em uso no VPS (não usar!) ----
# 80   - Nginx principal (SSL termination)
# 443  - Nginx principal (HTTPS)
# 4000 - Outro serviço
# 5432 - PostgreSQL principal
# 5678 - Outro serviço
# 6379 - Redis principal

# ---- Portas do PeladaPro (stack Docker) ----
# 3000 - Frontend Next.js
# 3001 - API Express
# 5433 - PostgreSQL (boleiros)
# 6380 - Redis (boleiros)
# 8080 - Nginx proxy (boleiros)
